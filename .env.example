# ─── Graph Backend ───────────────────────────────────────────────────────────
# Options: arcadedb | neo4j | age
GRAPH_BACKEND=arcadedb

# ArcadeDB (primary)
ARCADEDB_URL=http://localhost:2480
ARCADEDB_USER=root
ARCADEDB_PASSWORD=changeme
ARCADEDB_DATABASE=exobrain

# Neo4j (alternative)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ─── Database Backend ────────────────────────────────────────────────────────
# Options: postgres | sqlite | libsql
DB_BACKEND=postgres

# PostgreSQL (primary)
POSTGRES_URL=postgresql://exobrain:changeme@localhost:5433/exobrain

# SQLite (embedded/minimal tier)
SQLITE_PATH=./data/exobrain.db

# libSQL / Turso (embedded+sync tier)
LIBSQL_URL=file:./data/exobrain.db
# LIBSQL_AUTH_TOKEN=           # only needed for Turso cloud sync

# ─── MCP Server ──────────────────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme-replace-with-random-secret
REGISTRATION_SECRET=changeme-replace-with-random-secret

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Embedding ───────────────────────────────────────────────────────────────
# Leave EMBEDDING_BASE_URL unset to auto-detect llama.cpp server (port 8080)
# or Ollama (port 11434). Set explicitly to override.
#
# llama.cpp server (recommended):
#   llama-server --hf-repo nomic-ai/nomic-embed-text-v1.5-GGUF \
#       --hf-file nomic-embed-text-v1.5.Q8_0.gguf --port 8080 --embedding
#
# Ollama (if already installed):
#   ollama pull nomic-embed-text
#   (auto-detected at localhost:11434)
#
# EMBEDDING_BASE_URL=http://localhost:8080/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_KEY=
EMBEDDING_CHUNK_TOKENS=400     # entries longer than this are chunked
EMBEDDING_CHUNK_OVERLAP=80     # token overlap between chunks

# ─── Maintenance ─────────────────────────────────────────────────────────────
# How often to run background KG integrity + cleanup checks (milliseconds)
MAINTENANCE_INTERVAL_MS=300000   # 5 minutes default

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
